<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.soypete.exo</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd ~/code/exo && /Users/soypete/.local/bin/uv run exo</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/soypete/dotfiles/exo/logs/exo-startup.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/soypete/dotfiles/exo/logs/exo-startup-error.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>EXO_LIBP2P_NAMESPACE</key>
        <string>soypete-spark-cluster</string>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/soypete/.local/bin</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>/Users/soypete/code/exo</string>
</dict>
</plist>
