{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "ray/QuantTrio/MiniMax-M2.5-AWQ",
  "instructions": ["CLAUDE.md"],
  "formatter": {
    "goimports": {
      "command": ["goimports", "-w", "$FILE"],
      "extensions": [".go"]
    }
  },
  "lsp": {
    "go": {
      "command": ["gopls"],
      "extensions": [".go"],
      "env": {
        "GOTOOLCHAIN": "go1.24.5"
      }
    },
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"]
    },
    "nix": {
      "command": ["nil"],
      "extensions": [".nix"]
    }
  },
  "provider": {
    "ray": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ray Cluster",
      "options": {
        "baseURL": "http://100.87.122.109:8000/v1",
        "apiKey": "fake"
      },
      "models": {
        "QuantTrio/MiniMax-M2.5-AWQ": {
          "name": "MiniMax M2.5 AWQ",
          "limit": { "context": 1000000, "output": 8192 }
        }
      }
    }
  }
}
