{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "ray/QuantTrio/MiniMax-M2.5-AWQ",
  "instructions": ["CLAUDE.md"],
  "permission": {
    "skill": {
      "graphify": "allow",
      "llmwiki": "allow",
      "mempalace": "allow",
      "query-mem": "allow"
    }
  },
  "skill": {
    "graphify": {
      "command": ["python3", "/Users/soypete/code/opensource/experiments/skills/graphify.py"],
      "description": "Query Graphify knowledge graph"
    },
    "llmwiki": {
      "command": ["python3", "/Users/soypete/code/opensource/experiments/skills/llmwiki.py"],
      "description": "Query LLMWiki documentation"
    },
    "mempalace": {
      "command": ["python3", "/Users/soypete/code/opensource/experiments/skills/mempalace.py"],
      "description": "Query MemPalace semantic memory"
    },
    "query-mem": {
      "command": ["python3", "/Users/soypete/code/opensource/experiments/query_systems.py"],
      "description": "Query all memory systems"
    }
  },
  "command": {
    "save-session": {
      "template": "Save the important information from this session to memory. Run: ~/code/opensource/experiments/scripts/save-session.sh $SESSION_ID $TRANSCRIPT_PATH",
      "description": "Save session to memory systems"
    }
  },
  "formatter": {
    "goimports": {
      "command": ["goimports", "-w", "$FILE"],
      "extensions": [".go"]
    }
  },
  "lsp": {
    "go": {
      "command": ["gopls"],
      "extensions": [".go"],
      "env": {
        "GOTOOLCHAIN": "go1.24.5"
      }
    },
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"]
    },
    "nix": {
      "command": ["nil"],
      "extensions": [".nix"]
    }
  },
  "provider": {
    "ray": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ray Cluster",
      "options": {
        "baseURL": "http://100.87.122.109:8000/v1",
        "apiKey": "fake"
      },
      "models": {
        "QuantTrio/MiniMax-M2.5-AWQ": {
          "name": "MiniMax M2.5 AWQ",
          "limit": { "context": 100000, "output": 24000 }
        }
      }
    }
  }
}
