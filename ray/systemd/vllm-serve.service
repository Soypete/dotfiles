[Unit]
Description=vLLM Model Server (GLM-4.5-Air)
After=ray-head.service
Requires=ray-head.service

[Service]
Type=simple
User=soypete
WorkingDirectory=/home/soypete
ExecStartPre=/bin/bash -c 'sleep 10'
ExecStart=/bin/bash -c 'docker exec $(docker ps --format "{{.Names}}" | grep -E "^node-[0-9]+") bash -c "SAFETENSORS_FAST_GPU=1 vllm serve zai-org/GLM-4.5-Air --trust-remote-code --tensor-parallel-size 2 --distributed-executor-backend ray --max-model-len 32768 --enable-auto-tool-choice --tool-call-parser glm45 --reasoning-parser glm45 --compilation-config {\\\"cudagraph_mode\\\": \\\"PIECEWISE\\\"} --host 0.0.0.0 --port 8000"'
Restart=on-failure
RestartSec=60
TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
